# =============================================
# LOCAL RULES — Custom IDS/IPS Rules
# Kamsis Web Application Protection
# =============================================
# CATATAN: Semua rules ini TANPA keyword "flow"
# agar tidak membutuhkan preprocessor stream5.
# =============================================

# ===================
# CANARY TEST (hapus setelah testing selesai)
# ===================
alert tcp any any -> any any (msg:"[TEST] Snort is ALIVE - canary test"; content:"TESTSNORT"; nocase; sid:999999; rev:1;)

# ===================
# SQL INJECTION (SQLi)
# ===================

# SQLi: UNION SELECT (URL encoded: + atau %20 sebagai spasi)
alert tcp any any -> any $HTTP_PORTS (msg:"[SQLi] UNION SELECT attack detected"; content:"UNION"; nocase; content:"SELECT"; nocase; distance:0; within:20; sid:1000001; rev:3; classtype:web-application-attack;)

# SQLi: OR 1=1 bypass
alert tcp any any -> any $HTTP_PORTS (msg:"[SQLi] OR 1=1 bypass attempt"; content:"OR"; nocase; content:"1=1"; distance:0; within:15; sid:1000002; rev:3; classtype:web-application-attack;)

# SQLi: DROP TABLE
alert tcp any any -> any $HTTP_PORTS (msg:"[SQLi] DROP TABLE attempt"; content:"DROP"; nocase; content:"TABLE"; nocase; distance:0; within:15; sid:1000003; rev:2; classtype:web-application-attack;)

# SQLi: Comment injection (--)
alert tcp any any -> any $HTTP_PORTS (msg:"[SQLi] SQL comment injection (--)"; content:"--"; sid:1000004; rev:2; classtype:web-application-attack;)

# SQLi: Single quote injection
alert tcp any any -> any $HTTP_PORTS (msg:"[SQLi] Single quote injection"; content:"' OR "; nocase; sid:1000005; rev:1; classtype:web-application-attack;)

# SQLi: INSERT INTO
alert tcp any any -> any $HTTP_PORTS (msg:"[SQLi] INSERT INTO attempt"; content:"INSERT"; nocase; content:"INTO"; nocase; distance:0; within:15; sid:1000006; rev:1; classtype:web-application-attack;)

# SQLi: DELETE FROM
alert tcp any any -> any $HTTP_PORTS (msg:"[SQLi] DELETE FROM attempt"; content:"DELETE"; nocase; content:"FROM"; nocase; distance:0; within:15; sid:1000007; rev:1; classtype:web-application-attack;)

# SQLi: SLEEP / BENCHMARK (time-based blind SQLi)
alert tcp any any -> any $HTTP_PORTS (msg:"[SQLi] Time-based blind SQLi - SLEEP"; content:"SLEEP"; nocase; content:"("; distance:0; within:5; sid:1000008; rev:1; classtype:web-application-attack;)

# SQLi: information_schema access
alert tcp any any -> any $HTTP_PORTS (msg:"[SQLi] information_schema access"; content:"information_schema"; nocase; sid:1000009; rev:1; classtype:web-application-attack;)

# ===================
# CROSS-SITE SCRIPTING (XSS)
# ===================

# XSS: <script tag
alert tcp any any -> any $HTTP_PORTS (msg:"[XSS] Script tag detected"; content:"<script"; nocase; sid:1000010; rev:3; classtype:web-application-attack;)

# XSS: </script tag
alert tcp any any -> any $HTTP_PORTS (msg:"[XSS] Closing script tag detected"; content:"</script"; nocase; sid:1000013; rev:1; classtype:web-application-attack;)

# XSS: onerror event handler
alert tcp any any -> any $HTTP_PORTS (msg:"[XSS] onerror event handler"; content:"onerror"; nocase; content:"="; distance:0; within:5; sid:1000011; rev:2; classtype:web-application-attack;)

# XSS: onload event handler
alert tcp any any -> any $HTTP_PORTS (msg:"[XSS] onload event handler"; content:"onload"; nocase; content:"="; distance:0; within:5; sid:1000014; rev:1; classtype:web-application-attack;)

# XSS: onclick event handler
alert tcp any any -> any $HTTP_PORTS (msg:"[XSS] onclick event handler"; content:"onclick"; nocase; content:"="; distance:0; within:5; sid:1000015; rev:1; classtype:web-application-attack;)

# XSS: onmouseover event handler
alert tcp any any -> any $HTTP_PORTS (msg:"[XSS] onmouseover event handler"; content:"onmouseover"; nocase; content:"="; distance:0; within:5; sid:1000016; rev:1; classtype:web-application-attack;)

# XSS: javascript: protocol
alert tcp any any -> any $HTTP_PORTS (msg:"[XSS] javascript: protocol detected"; content:"javascript"; nocase; content:":"; distance:0; within:3; sid:1000012; rev:2; classtype:web-application-attack;)

# XSS: alert() function
alert tcp any any -> any $HTTP_PORTS (msg:"[XSS] alert() function detected"; content:"alert("; nocase; sid:1000017; rev:1; classtype:web-application-attack;)

# XSS: document.cookie theft
alert tcp any any -> any $HTTP_PORTS (msg:"[XSS] document.cookie access"; content:"document.cookie"; nocase; sid:1000018; rev:1; classtype:web-application-attack;)

# XSS: eval() function
alert tcp any any -> any $HTTP_PORTS (msg:"[XSS] eval() function detected"; content:"eval("; nocase; sid:1000019; rev:1; classtype:web-application-attack;)

# ===================
# BRUTE FORCE LOGIN
# ===================
alert tcp any any -> any $HTTP_PORTS (msg:"[BruteForce] Banyak POST /login dalam waktu singkat"; content:"POST"; content:"/login"; detection_filter:track by_src, count 10, seconds 30; sid:1000020; rev:3; classtype:attempted-user;)

# ===================
# BUFFER OVERFLOW
# ===================
alert tcp any any -> any $HTTP_PORTS (msg:"[BufferOverflow] Payload HTTP sangat besar (>8KB)"; dsize:>8192; sid:1000030; rev:2; classtype:attempted-dos;)

# ===================
# DATABASE ACCESS
# ===================
alert tcp any any -> any 3306 (msg:"[DB] Koneksi MySQL terdeteksi"; content:"|00 00 01|"; depth:5; sid:1000040; rev:2; classtype:attempted-user;)

# ===================
# PORT SCAN / RECON
# ===================
alert tcp any any -> any any (msg:"[Recon] TCP SYN port scan terdeteksi"; flags:S; detection_filter:track by_src, count 20, seconds 5; sid:1000050; rev:2; classtype:attempted-recon;)

# ===================
# PATH TRAVERSAL / LFI
# ===================
alert tcp any any -> any $HTTP_PORTS (msg:"[LFI] Path traversal ../ detected"; content:"../"; sid:1000060; rev:2; classtype:web-application-attack;)

alert tcp any any -> any $HTTP_PORTS (msg:"[LFI] Path traversal ..%5c detected"; content:"..%5c"; nocase; sid:1000061; rev:1; classtype:web-application-attack;)

# ===================
# COMMAND INJECTION
# ===================
alert tcp any any -> any $HTTP_PORTS (msg:"[CMDi] Command injection - pipe |"; content:"|7c|"; content:"cat "; nocase; distance:0; within:20; sid:1000070; rev:1; classtype:web-application-attack;)

alert tcp any any -> any $HTTP_PORTS (msg:"[CMDi] Command injection - /etc/passwd"; content:"/etc/passwd"; sid:1000071; rev:1; classtype:web-application-attack;)

alert tcp any any -> any $HTTP_PORTS (msg:"[CMDi] Command injection - /bin/sh"; content:"/bin/sh"; sid:1000072; rev:1; classtype:web-application-attack;)